RewriteEngine On
RewriteBase /

# 1. Redirect external requests for /file.html to /file (URL normalization)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Resolve /file to /file.html internally with web-root slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ /$1.html [L]
